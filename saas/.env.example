# GitHub OAuth Configuration
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Flask Configuration
FLASK_SECRET_KEY=your_flask_secret_key_here_at_least_32_characters_long

# Optional: Flask Environment
FLASK_ENV=production

# Optional: GitHub OAuth Callback URL (should match your GitHub OAuth App settings)
# For local development: http://localhost:5000/callback
# For Docker: http://localhost:5000/callback
# For production with domain: https://your-domain.com/callback
